APP_ENV=local
APP_NAME=Boat Backend
API_PREFIX=/api/v1
DATABASE_URL=postgresql+asyncpg://boat:boat@localhost:5432/boat
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS_PATH=
FIREBASE_CHECK_REVOKED=false
FIREBASE_APP_NAME=boat-backend-auth
FIREBASE_PROJECT_ID_OPTION=projectId
FIREBASE_ISSUER=firebase
FIREBASE_DEFAULT_PROVIDER=firebase
FIREBASE_UID_CLAIM=uid
FIREBASE_SUBJECT_CLAIM=sub
FIREBASE_EMAIL_CLAIM=email
FIREBASE_NAME_CLAIM=name
FIREBASE_NAMESPACE_CLAIM=firebase
FIREBASE_SIGN_IN_PROVIDER_CLAIM=sign_in_provider
JWT_SECRET_KEY=local-development-secret-change-me-32bytes
JWT_ALGORITHM=HS256
JWT_ISSUER=boat-backend
JWT_AUDIENCE=boat-api
ACCESS_TOKEN_EXPIRES_MINUTES=30
REFRESH_TOKEN_EXPIRES_DAYS=14
REFRESH_TOKEN_PEPPER=local-refresh-token-pepper-change-me
